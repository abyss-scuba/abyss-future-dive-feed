# Source and output
SOURCE_URL=https://www.abyss.com.au/widget-all
OUTPUT_DIR=data

# DS360 loading behaviour
MIN_INITIAL_DELAY_MS=10000
WIDGET_TIMEOUT_MS=90000
STABILITY_POLL_MS=1000
STABLE_POLLS_REQUIRED=3
FINAL_SETTLE_MS=1500

# Feed windows
FUTURE_START_OFFSET_DAYS=21
MAX_STALE_HOURS=48
MAX_PAGES_PER_SOURCE=10

# Browser settings
HEADLESS=true
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Set to 1 only for local testing against a saved rendered HTML file.
# HTML_FIXTURE_PATH=/absolute/path/to/rendered-widget-all.html
