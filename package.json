{
  "name": "abyss-future-dive-scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Scrapes Abyss DS360 widget calendars into a validated future-dive JSON feed.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "scrape": "node scripts/scrape-widget-all.mjs",
    "validate": "node scripts/validate-feed.mjs data/future-dives.json",
    "summary": "node scripts/summarise-feed.mjs data/future-dives.json",
    "test": "node --test tests/*.test.mjs",
    "check": "npm test && npm run validate"
  },
  "dependencies": {
    "luxon": "3.7.2",
    "playwright": "1.61.1"
  }
}
